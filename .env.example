# DB — Supabase Postgres
#  DATABASE_URL: 풀러(pgbouncer, 6543) 연결 — 런타임용. 끝에 ?pgbouncer=true 권장
#  DIRECT_URL  : 직접(5432) 연결 — 마이그레이션용
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# 파일 저장 — Supabase Storage
SUPABASE_URL=https://lzclvjdjemfkyskvtbyn.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service_role_key...
SUPABASE_BUCKET=uploads

