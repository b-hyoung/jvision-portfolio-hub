# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
# 공개 CA 중간 인증서는 런타임에 필요하므로 커밋에 포함 (비밀키 아님)
!certs/*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# app data
/uploads
/prisma/dev.db
/prisma/dev.db-journal

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code
.claude
