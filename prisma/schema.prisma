generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  studentNo  String   @unique
  name       String?
  department String?
  createdAt  DateTime @default(now())
  posts      Post[]
}

model Post {
  id          String   @id @default(cuid())
  type        String // RESUME | COVER_LETTER | PORTFOLIO
  title       String
  description String?
  filePath    String?
  fileName    String?
  previewPath String? // PPTX 등을 변환한 미리보기용 PDF 경로
  linkUrl     String?
  createdAt   DateTime @default(now())
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId    String
}
